//FUNCTIONS
function IA_bulbe_métallique() {
moveToward(getSummoner())

    useChip(CHIP_ARMOR, getSummoner())
	useChip(CHIP_WALL, getSummoner())
	useChip(CHIP_WINGED_BOOTS, getSummoner())
    useChip(CHIP_SHIELD, getSummoner())
    
}

function IA_bulbe_savant() {
	if (getPathLength(getCell(), getCell(getSummoner())) > 2) {
	moveToward(getSummoner(), getPathLength(getCell(), getCell(getSummoner()) - 2))
}
	if (getPathLength(getCell(), getCell(getSummoner())) <= 2) {
	moveAwayFrom(getSummoner(), 1)
}

    useChip(CHIP_MUTATION, getSummoner())
	useChip(CHIP_ADRENALINE, getSummoner())
	useChip(CHIP_THORN, getSummoner())
    useChip(CHIP_ALTERATION, getNearestEnemy())
    
}

function IA_bulbe_heal() {
	if (getPathLength(getCell(), getCell(getSummoner())) > 2) {
	moveToward(getSummoner(), getPathLength(getCell(), getCell(getSummoner()) - 2))
}
	if (getPathLength(getCell(), getCell(getSummoner())) <= 2) {
	moveAwayFrom(getSummoner(), 1)
}

    useChip(CHIP_CURE, getSummoner())
	
if (getLife(getSummoner()) < getTotalLife(getSummoner())) {
	useChip(CHIP_VACCINE, getSummoner())
	useChip(CHIP_DRIP, getSummoner())
    useChip(CHIP_BANDAGE, getSummoner())
}   
}


